@page "/"
@using DocuGenious.Blazor.Models
@using DocuGenious.Blazor.Services
@using static FileStorageService
@inject DocumentationApiService Api
@inject ValidationService Validator
@inject FileStorageService Storage
@inject IJSRuntime JS

<PageTitle>Docu-Genius</PageTitle>

<div class="dg-card">

    <!-- HEADER -->
    <div class="dg-header">
        <h1>🚀 Docu-Genius</h1>
        <p class="dg-subtitle">AI-powered documentation in seconds</p>
    </div>

    <!-- SOURCE -->
    <p class="dg-section-title">Source</p>

    <div class="dg-field">
        <label class="dg-label">Choose an option</label>
        <select class="dg-select" @bind="_sourceType">
            <option value="">-- Select --</option>
            @foreach (var opt in SourceTypes.Options)
            {
                <option value="@opt.Value">@opt.Label</option>
            }
        </select>
    </div>

    @if (ShowJira)
    {
        <div class="dg-field">
            <label class="dg-label">JIRA Ticket ID(s)</label>
            <div class="dg-tag-wrapper" @onclick="FocusTagInput">
                @foreach (var tag in _ticketIds)
                {
                    <span class="dg-tag">
                        @tag
                        <button type="button" class="dg-tag-remove"
                                @onclick="() => RemoveTicket(tag)">
                            ✕
                        </button>
                    </span>
                }
                <input id="tag-input"
                       class="dg-tag-input"
                       placeholder="e.g. PROJ-123"
                       @bind="_ticketInput"
                       @bind:event="oninput"
                       @onkeydown="HandleTagKeyDown" />
            </div>
            <p class="dg-hint">Press Enter or comma</p>
        </div>
    }

    @if (ShowGit)
    {
        <div class="dg-field">
            <label class="dg-label">Repository URL</label>
            <input class="dg-input" @bind="_repoUrl" />
        </div>

        <div class="dg-field">
            <label class="dg-label">Branch</label>
            <input class="dg-input" @bind="_branch" />
        </div>
    }

    <hr class="dg-divider" />

    <!-- OUTPUT -->
    <p class="dg-section-title">Output</p>

    <div class="dg-field">
        <label class="dg-label">Document Type</label>
        <select class="dg-select" @bind="_docType">
            @foreach (var opt in DocumentationTypes.Options)
            {
                <option value="@opt.Value">@opt.Label</option>
            }
        </select>
    </div>

    <div class="dg-field">
        <label class="dg-label">Additional Context</label>
        <textarea class="dg-textarea" @bind="_additionalContext"></textarea>
    </div>

    <div class="dg-field">
        <label class="dg-label">File Name</label>
        <input class="dg-input" @bind="_outputFileName" />
    </div>
    <div class="mx-2"
         style="display: flex; justify-content: flex-end; gap: 0.75rem;">
    
        <button class="dg-btn-secondary"
                @onclick="clear">
            Clear
        </button>

        <button class="dg-btn-primary"
                @onclick="StartValidation"
                disabled="@(!CanSubmit)">
            ✨ Generate
        </button>

    </div>


    <!-- FILE HISTORY GRID -->
    @if (_files.Any())
    {
        <div style="margin-top:25px">
            <p class="dg-section-title">Generated Files</p>

            <table class="dg-table">
                <thead>
                    <tr>
                        <th>File Name</th>
                        <th>Created On</th>
                        <th></th>
                    </tr>
                </thead>

                <tbody>
                    @foreach (var f in _files)
                    {
                        <tr>
                            <td>@f.FileName</td>
                            <td>@f.CreatedOn.ToString("dd-MMM-yyyy HH:mm")</td>
                            <td>
                                <button class="dg-btn-download"
                                        @onclick="() => DownloadPdf(f.FileName)">
                                    Download
                                </button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }

</div>

<!-- POPUP -->
@if (_showDialog)
{
    <div class="dg-modal-overlay">
        <div class="dg-modal">

            @if (_state == UiState.Generating)
            {
                <div class="dg-progress">
                    <div class="dg-spinner"></div>
                    <p>Generating document...</p>
                </div>
            }

            @if (_state == UiState.Success)
            {
                <div class="dg-alert dg-alert-success">
                    <strong>Document generated!</strong><br />
                    @_result?.FileName
                </div>

                <button class="dg-btn-download" @onclick="() => DownloadPdf()">
                    ⬇️ Download
                </button>

                <button class="dg-btn-ghost" @onclick="CloseDialog">
                    Close
                </button>
            }

            @if (_state == UiState.Error)
            {
                <div class="dg-alert dg-alert-error">
                    @_errorMessage
                </div>

                <button class="dg-btn-ghost" @onclick="CloseDialog">
                    Close
                </button>
            }

        </div>
    </div>
}

<style>
    .dg-modal-overlay {
        position: fixed;
        inset: 0;
        background: rgba(0,0,0,0.5);
        display: flex;
        justify-content: center;
        align-items: center;
        z-index: 999;
    }

    .dg-modal {
        background: white;
        padding: 25px;
        border-radius: 12px;
        min-width: 320px;
        text-align: center;
    }

    .dg-table {
        width: 100%;
        border-collapse: collapse;
    }

        .dg-table th, .dg-table td {
            padding: 10px;
            border-bottom: 1px solid #eee;
        }
</style>

@code {

    private enum UiState { Form, Generating, Success, Error }
    private UiState _state = UiState.Form;

    private bool _showDialog = false;

    private string _sourceType = "";
    private string _docType = "FullDocumentation";
    private string _repoUrl = "";
    private string _branch = "";
    private string _additionalContext = "";
    private string _outputFileName = "";
    private string _ticketInput = "";
    private List<string> _ticketIds = new();

    private List<FileRecord> _files = new();

    private GenerateResult? _result;
    private string _errorMessage = "";

    private bool ShowJira => _sourceType is "JiraOnly" or "Both";
    private bool ShowGit => _sourceType is "GitOnly" or "Both";

    private bool CanSubmit =>
        !string.IsNullOrEmpty(_sourceType) &&
        (!ShowJira || _ticketIds.Count > 0 || !string.IsNullOrWhiteSpace(_ticketInput)) &&
        (!ShowGit || !string.IsNullOrWhiteSpace(_repoUrl));

    protected override async Task OnInitializedAsync()
    {
        _files = await Storage.GetFilesAsync() ?? new();
    }

    private async Task StartValidation()
    {
        if (!string.IsNullOrWhiteSpace(_ticketInput))
            AddTicket();

        await Generate();
    }
    private void clear()
    {
        _sourceType = "";
        _ticketInput = "";
        _repoUrl = "";
        _branch = "";
        _docType = "";
        _additionalContext = "";
        _outputFileName = "";
        _ticketIds = [];
		StateHasChanged();
    }
    private async Task Generate()
    {
        _showDialog = true;
        _state = UiState.Generating;

        var request = new GenerateRequest
        {
            SourceType = _sourceType,
            JiraTicketIds = _ticketIds,
            GitRepositoryUrl = ShowGit ? _repoUrl : null,
            GitBranch = _branch,
            DocumentationType = _docType,
            AdditionalContext = _additionalContext,
            OutputFileName = _outputFileName
        };

        _result = await Api.GenerateDocumentAsync(request);

        if (_result.Success)
        {
            _state = UiState.Success;
            clear();
            var file = new FileRecord
            {
                FileName = _result.FileName,
                CreatedOn = DateTime.Now
            };

            _files.Insert(0, file);
            await Storage.SaveFilesAsync(_files);
        }
        else
        {
            _state = UiState.Error;
            _errorMessage = _result.Error ?? "Error occurred";
        }
    }

    private void CloseDialog()
    {
        _showDialog = false;
        _state = UiState.Form;
    }

    private async Task DownloadPdf(string? fileName = null)
    {
        fileName ??= _result?.FileName;
        if (fileName == null) return;

        var bytes = await Api.DownloadPdfAsync(fileName);
        var base64 = Convert.ToBase64String(bytes);

        await JS.InvokeVoidAsync("downloadFileFromBase64",
            base64, fileName, "application/pdf");
    }

    private void HandleTagKeyDown(KeyboardEventArgs e)
    {
        if (e.Key is "Enter" or ",") AddTicket();
    }

    private void AddTicket()
    {
        var val = _ticketInput.Trim().Trim(',');
        if (!string.IsNullOrWhiteSpace(val))
            _ticketIds.Add(val.ToUpper());

        _ticketInput = "";
    }

    private void RemoveTicket(string t) => _ticketIds.Remove(t);

    private async Task FocusTagInput()
        => await JS.InvokeVoidAsync("eval",
            "document.getElementById('tag-input')?.focus()");
}