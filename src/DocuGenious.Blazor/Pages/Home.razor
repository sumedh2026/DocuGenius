@page "/"
@using DocuGenious.Blazor.Models
@using DocuGenious.Blazor.Services
@using static FileStorageService
@inject DocumentationApiService Api
@inject ValidationService Validator
@inject FileStorageService Storage
@inject IJSRuntime JS

<PageTitle>Docu-Genius</PageTitle>

<div class="dg-card">

    <!-- HEADER -->
    <div class="dg-header">
        <h1>🚀 Docu-Genius</h1>
        <p class="dg-subtitle">AI-powered documentation in seconds</p>
    </div>

    <!-- SOURCE -->
    <p class="dg-section-title">Source</p>

    <div class="dg-field">
        <label class="dg-label">Choose an option</label>
        <select class="dg-select" @bind="_sourceType">
            <option value="">-- Select --</option>
            @foreach (var opt in SourceTypes.Options)
            {
                <option value="@opt.Value">@opt.Label</option>
            }
        </select>
    </div>

    @if (ShowJira)
    {
        <div class="dg-field">
            <label class="dg-label">JIRA Ticket ID(s)</label>
            <div class="dg-tag-wrapper" @onclick="FocusTagInput">
                @foreach (var tag in _ticketIds)
                {
                    <span class="dg-tag">
                        @tag
                        <button type="button" class="dg-tag-remove"
                                @onclick="() => RemoveTicket(tag)">
                            ✕
                        </button>
                    </span>
                }
                <input id="tag-input"
                       class="dg-tag-input"
                       placeholder="e.g. PROJ-123"
                       @bind="_ticketInput"
                       @bind:event="oninput"
                       @onkeydown="HandleTagKeyDown" />
            </div>
            <p class="dg-hint">Press Enter or comma</p>
        </div>
    }

    @if (ShowGit)
    {
        <div class="dg-field">
            <label class="dg-label">Repository URL</label>
            <input class="dg-input" @bind="_repoUrl" />
        </div>

        <div class="dg-field">
            <label class="dg-label">Branch</label>
            <input class="dg-input" @bind="_branch" />
        </div>
    }

    <hr class="dg-divider" />

    <!-- OUTPUT -->
    <p class="dg-section-title">Output</p>

    <div class="dg-field">
        <label class="dg-label">Document Type</label>
        <select class="dg-select" @bind="_docType">
            @foreach (var opt in DocumentationTypes.Options)
            {
                <option value="@opt.Value">@opt.Label</option>
            }
        </select>
    </div>

    <div class="dg-field">
        <label class="dg-label">Additional Context</label>
        <textarea class="dg-textarea" @bind="_additionalContext"></textarea>
    </div>

    <div class="dg-field">
        <label class="dg-label">File Name</label>
        <input class="dg-input" @bind="_outputFileName" />
    </div>
    <div class="mx-2"
         style="display: flex; justify-content: flex-end; gap: 0.75rem;">
    
        <button class="dg-btn-secondary"
                @onclick="clear">
            Clear
        </button>

        <button class="dg-btn-primary"
                @onclick="StartValidation"
                disabled="@(!CanSubmit)">
            ✨ Generate
        </button>

    </div>

    <!-- FILE HISTORY LIST -->
    @if (_files.Any())
    {
        <div style="margin-top:25px">
            <p class="dg-section-title">Generated Files</p>

            <div class="dg-files-list">
                @foreach (var f in _files)
                {
                    <div class="dg-file-row">
                        <span class="dg-file-icon">📄</span>
                        <span class="dg-file-name" title="@f.FileName">@f.FileName</span>
                        <span class="dg-file-date">@f.CreatedOn.ToString("dd MMM yyyy, HH:mm")</span>
                        <button class="dg-btn-download dg-btn-download-sm"
                                @onclick="() => DownloadPdf(f.FileName)">
                            ⬇ Download
                        </button>
                    </div>
                }
            </div>
        </div>
    }

</div>

<!-- POPUP -->
@if (_showDialog)
{
    <div class="dg-modal-overlay">
        <div class="dg-modal">

            @if (_state == UiState.Generating)
            {
                <div class="dg-progress">
                    <div class="dg-spinner"></div>
                    <p class="dg-status-text">@_statusMessage</p>
                </div>

                <button class="dg-btn-ghost" @onclick="CloseDialog">
                    Hide
                </button>
            }

            @if (_state == UiState.Success)
            {
                <div class="dg-alert dg-alert-success">
                    <strong>Document generated!</strong><br />
                    @_result?.FileName
                </div>

                <button class="dg-btn-download" @onclick="() => DownloadPdf()">
                    ⬇️ Download
                </button>

                <button class="dg-btn-ghost" @onclick="CloseDialog">
                    Close
                </button>
            }

            @if (_state == UiState.Error)
            {
                <div class="dg-alert dg-alert-error">
                    @_errorMessage
                </div>

                <button class="dg-btn-ghost" @onclick="CloseDialog">
                    Close
                </button>
            }

        </div>
    </div>
}

<style>
    .dg-modal-overlay {
        position: fixed;
        inset: 0;
        background: rgba(0,0,0,0.5);
        display: flex;
        justify-content: center;
        align-items: center;
        z-index: 999;
    }

    .dg-modal {
        background: white;
        padding: 25px;
        border-radius: 12px;
        min-width: 320px;
        text-align: center;
    }

    .dg-status-text {
        margin: 10px 0 0;
        font-size: 0.95rem;
        color: #374151;
        min-height: 1.4em;
        transition: opacity 0.3s ease;
    }

    .dg-files-list {
        display: flex;
        flex-direction: column;
        gap: 8px;
    }

    .dg-file-row {
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 10px 14px;
        background: #f9fafb;
        border: 1px solid #e5e7eb;
        border-radius: 8px;
    }

    .dg-file-icon {
        flex-shrink: 0;
        font-size: 1.1rem;
    }

    .dg-file-name {
        flex: 1 1 0;
        min-width: 0;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
        font-size: 0.9rem;
        font-weight: 500;
        color: #111827;
    }

    .dg-file-date {
        flex-shrink: 0;
        font-size: 0.8rem;
        color: #6b7280;
        white-space: nowrap;
    }

    /* Compact download button used inside the file-history rows.
       Overrides the full-width / large-padding defaults from app.css. */
    .dg-btn-download-sm {
        width: auto;
        flex-shrink: 0;
        padding: 6px 14px;
        font-size: 0.82rem;
        margin-top: 0;
    }
</style>

@code {

    private enum UiState { Form, Generating, Success, Error }
    private UiState _state = UiState.Form;

    private bool _showDialog = false;

    // ─── Live status ──────────────────────────────────────────────────────────────
    private string _statusMessage = "⏳ Starting…";
    private CancellationTokenSource? _pollingCts;

    private string _sourceType = "";
    private string _docType = "FullDocumentation";
    private string _repoUrl = "";
    private string _branch = "";
    private string _additionalContext = "";
    private string _outputFileName = "";
    private string _ticketInput = "";
    private List<string> _ticketIds = new();

    private List<FileRecord> _files = new();

    private GenerateResult? _result;
    private string _errorMessage = "";

    private bool ShowJira => _sourceType is "JiraOnly" or "Both";
    private bool ShowGit => _sourceType is "GitOnly" or "Both";

    private bool CanSubmit =>
        !string.IsNullOrEmpty(_sourceType) &&
        (!ShowJira || _ticketIds.Count > 0 || !string.IsNullOrWhiteSpace(_ticketInput)) &&
        (!ShowGit || !string.IsNullOrWhiteSpace(_repoUrl));

    protected override async Task OnInitializedAsync()
    {
        _files = await Storage.GetFilesAsync() ?? new();
    }

    private async Task StartValidation()
    {
        if (!string.IsNullOrWhiteSpace(_ticketInput))
            AddTicket();

        await Generate();
    }
    private void clear()
    {
        _sourceType = "";
        _ticketInput = "";
        _repoUrl = "";
        _branch = "";
        _docType = "FullDocumentation";
        _additionalContext = "";
        _outputFileName = "";
        _ticketIds = [];
		StateHasChanged();
    }
    private async Task Generate()
    {
        _showDialog      = true;
        _state           = UiState.Generating;
        _statusMessage   = "⏳ Starting…";

        // Unique ID lets the server push status updates that we can poll
        var jobId = Guid.NewGuid().ToString("N");

        var request = new GenerateRequest
        {
            SourceType       = _sourceType,
            JiraTicketIds    = _ticketIds,
            GitRepositoryUrl = ShowGit ? _repoUrl : null,
            GitBranch        = _branch,
            DocumentationType = _docType,
            AdditionalContext = _additionalContext,
            OutputFileName   = _outputFileName,
            JobId            = jobId
        };

        // Start background polling — fire-and-forget, cancelled when generate returns
        _pollingCts = new CancellationTokenSource();
        _ = PollStatusAsync(jobId, _pollingCts.Token);

        _result = await Api.GenerateDocumentAsync(request);

        // Stop polling regardless of outcome
        _pollingCts.Cancel();
        _pollingCts.Dispose();
        _pollingCts = null;

        if (_result.Success)
        {
            var file = new FileRecord
            {
                FileName  = _result.FileName,
                CreatedOn = DateTime.Now
            };

            _files.Insert(0, file);
            await Storage.SaveFilesAsync(_files);

            // Only pop the success dialog if the user hasn't already hidden it.
            // If they clicked "Hide" while it was generating, the file now
            // silently appears in the list below.
            if (_showDialog)
                _state = UiState.Success;
            else
                _state = UiState.Form;
        }
        else
        {
            _state        = UiState.Error;
            _errorMessage = _result.Error ?? "Error occurred";
            // Always re-show the dialog for errors so the user sees what went wrong
            _showDialog   = true;
        }
    }

    /// <summary>
    /// Polls the server for the current job status every 1.5 s and updates
    /// _statusMessage so the spinner dialog shows what the API is doing.
    /// </summary>
    private async Task PollStatusAsync(string jobId, CancellationToken ct)
    {
        try
        {
            while (!ct.IsCancellationRequested)
            {
                await Task.Delay(1500, ct);

                var status = await Api.GetJobStatusAsync(jobId);
                if (!string.IsNullOrWhiteSpace(status) && status != _statusMessage)
                {
                    _statusMessage = status;
                    StateHasChanged();
                }
            }
        }
        catch (OperationCanceledException) { /* normal cancellation — do nothing */ }
        catch { /* polling errors are non-fatal; UI keeps last known status */ }
    }

    private void CloseDialog()
    {
        // Clear the form only after a successful generation so the user can
        // start fresh. On error, keep the fields so they can fix and retry.
        if (_state == UiState.Success)
            ResetForm();

        _showDialog = false;

        // If generation is still running, leave _state as Generating so
        // Generate() can still resolve correctly when it finishes:
        //   - Success → file is silently added to the list (no modal re-shown)
        //   - Error   → modal is re-shown so the user still sees the error
        if (_state != UiState.Generating)
            _state = UiState.Form;
    }

    private void ResetForm()
    {
        _sourceType        = "";
        _docType           = "FullDocumentation";
        _repoUrl           = "";
        _branch            = "";
        _additionalContext = "";
        _outputFileName    = "";
        _ticketInput       = "";
        _ticketIds         = new();
        _result            = null;
        _errorMessage      = "";
        _statusMessage     = "⏳ Starting…";

        // Cancel any in-flight polling (shouldn't happen, but defensive)
        _pollingCts?.Cancel();
        _pollingCts?.Dispose();
        _pollingCts = null;
    }

    private async Task DownloadPdf(string? fileName = null)
    {
        fileName ??= _result?.FileName;
        if (fileName == null) return;

        var bytes = await Api.DownloadPdfAsync(fileName);
        var base64 = Convert.ToBase64String(bytes);

        await JS.InvokeVoidAsync("downloadFileFromBase64",
            base64, fileName, "application/pdf");
    }

    private void HandleTagKeyDown(KeyboardEventArgs e)
    {
        if (e.Key is "Enter" or ",") AddTicket();
    }

    private void AddTicket()
    {
        var val = _ticketInput.Trim().Trim(',');
        if (!string.IsNullOrWhiteSpace(val))
            _ticketIds.Add(val.ToUpper());

        _ticketInput = "";
    }

    private void RemoveTicket(string t) => _ticketIds.Remove(t);

    private async Task FocusTagInput()
        => await JS.InvokeVoidAsync("eval",
            "document.getElementById('tag-input')?.focus()");
}